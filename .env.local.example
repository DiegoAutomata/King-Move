# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects y password reset)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenRouter (AI Tutor en /learn)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# Sentry (error monitoring)
# Obtener en: https://sentry.io → New Project → Next.js
NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...
# Opcional: para subir source maps en CI/CD
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=king-move
SENTRY_AUTH_TOKEN=sntrys_...
